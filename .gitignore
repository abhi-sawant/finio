# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files — keep .env.example tracked, ignore the rest
.env
.env.local
.env*.local
.env.development
.env.production
.env.staging

# Backend config (should live outside the project root on the server,
# but guard here in case it is ever placed inside for local testing)
backend/config.php

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Backend – Composer generated files (installed on server, not committed)
backend/vendor/
backend/composer.phar
backend/composer.lock
